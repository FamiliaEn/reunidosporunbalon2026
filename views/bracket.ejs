<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>🏆 FIFA World Cup 2026 – Bracket Oficial</title>
<meta name="description" content="Bracket oficial eliminatorio del FIFA World Cup 2026. Sigue el fixture completo desde la Ronda de 32 hasta la Gran Final en Nueva York el 19 de Julio 2026." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800;900&display=swap" rel="stylesheet" />
<style>
/* ═══════════════════════════════════════════
   TOKENS
═══════════════════════════════════════════ */
:root {
  --bg:         #08112A;
  --royal:      #1034A6;
  --dark:       #071650;
  --deeper:     #050F3A;
  --box:        #0C1E6B;
  --box2:       #091858;
  --border:     rgba(74,140,255,0.32);
  --border-gld: rgba(255,215,0,0.55);
  --acc:        #4A8CFF;
  --gold:       #FFD700;
  --txt:        #FFFFFF;
  --muted:      rgba(200,220,255,0.6);
  --r:          9px;
  --mw:         168px;
  --mh:         62px;
}

/* ═══════════════════════════════════════════
   BASE
═══════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background-color: var(--bg);
  background-image:
    radial-gradient(ellipse 90% 55% at 50% -5%, rgba(16,52,180,0.5), transparent 60%),
    radial-gradient(ellipse 50% 35% at 15% 90%, rgba(10,30,120,0.25), transparent 55%),
    radial-gradient(ellipse 50% 35% at 85% 90%, rgba(10,30,120,0.25), transparent 55%);
  color: var(--txt);
  font-family: 'Outfit', system-ui, sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ═══════════════════════════════════════════
   HEADER
═══════════════════════════════════════════ */
.site-header {
  text-align: center;
  padding: 40px 20px 28px;
  position: relative;
}

.bracket-nav {
  position: absolute;
  top: 8px;
  left: 0;
  right: 0;
  height: 36px;
  display: flex;
  align-items: center;
  background: #212529;
  z-index: 12;
}

.bracket-nav-inner {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 0;
  padding: 0 12px;
}

.bracket-nav-link,
.bracket-nav-dropbtn {
  display: inline-flex;
  align-items: center;
  height: 36px;
  padding: 0 8px;
  color: rgba(255,255,255,0.86);
  font-size: 16px;
  font-weight: 400;
  line-height: 1;
  text-decoration: none;
  background: transparent;
  border: 0;
  font-family: Arial, sans-serif;
  cursor: pointer;
}

.bracket-nav-link:hover,
.bracket-nav-dropbtn:hover,
.bracket-nav-link.active {
  color: #fff;
}

.bracket-nav-dropdown {
  position: relative;
  height: 36px;
}

.bracket-nav-dropbtn::after {
  content: "";
  display: inline-block;
  margin-left: 6px;
  border-top: 4px solid;
  border-right: 4px solid transparent;
  border-left: 4px solid transparent;
}

.bracket-nav-menu {
  display: none;
  position: absolute;
  top: 36px;
  left: 0;
  min-width: 160px;
  padding: 8px 0;
  background: #fff;
  border: 1px solid rgba(0,0,0,0.15);
  border-radius: 4px;
  box-shadow: 0 8px 18px rgba(0,0,0,0.18);
  text-align: left;
  z-index: 20;
}

.bracket-nav-dropdown:hover .bracket-nav-menu,
.bracket-nav-dropdown:focus-within .bracket-nav-menu {
  display: block;
}

.bracket-nav-item {
  display: block;
  padding: 4px 16px;
  color: #212529;
  font-family: Arial, sans-serif;
  font-size: 16px;
  line-height: 1.5;
  text-decoration: none;
  white-space: nowrap;
}

.bracket-nav-item:hover {
  color: #1e2125;
  background: #e9ecef;
}

.bracket-nav-spacer {
  flex: 1;
}

.hdr-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(74,140,255,0.1);
  border: 1px solid rgba(74,140,255,0.35);
  border-radius: 100px;
  padding: 5px 20px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--acc);
  margin-bottom: 16px;
}

.hdr-title {
  font-size: clamp(26px, 4.5vw, 54px);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -1px;
  background: linear-gradient(140deg, #fff 0%, #BDD4FF 45%, var(--acc) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hdr-sub {
  margin-top: 10px;
  font-size: 13px;
  font-weight: 400;
  color: var(--muted);
  letter-spacing: 1.5px;
}

.hdr-divider {
  width: 180px;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--acc), transparent);
  margin: 18px auto 0;
  border-radius: 2px;
}

.bracket-toggle-btn {
  margin: 18px auto 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 18px;
  border: 1px solid rgba(255,255,255,0.16);
  border-radius: 999px;
  background: rgba(255,255,255,0.06);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  cursor: pointer;
  transition: background .18s, border-color .18s, transform .12s;
}

.bracket-toggle-btn:hover {
  background: rgba(255,255,255,0.12);
  border-color: rgba(74,140,255,0.35);
}

#cp .bracket-toggle-btn {
  position: absolute;
  top: 8px;
  left: 50%;
  transform: translateX(-50%);
  margin: 0;
  z-index: 6;
}

/* ═══════════════════════════════════════════
   SECTION TITLE
═══════════════════════════════════════════ */
.sec-title {
  text-align: center;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--acc);
  margin-bottom: 22px;
  position: relative;
}
.sec-title::before,
.sec-title::after {
  content: '';
  position: absolute;
  top: 50%;
  height: 1px;
  width: 100px;
  background: linear-gradient(90deg, transparent, var(--acc));
}
.sec-title::before { right: calc(50% + 90px); transform: scaleX(-1); }
.sec-title::after  { left: calc(50% + 90px); }

/* ═══════════════════════════════════════════
   BRACKET SECTION
═══════════════════════════════════════════ */
.bracket-section { padding: 8px 0 32px; }

.scroll-wrap {
  overflow-x: auto;
  padding: 0 16px 12px;
  -webkit-overflow-scrolling: touch;
}
.scroll-wrap::-webkit-scrollbar { height: 5px; }
.scroll-wrap::-webkit-scrollbar-track { background: transparent; }
.scroll-wrap::-webkit-scrollbar-thumb { background: var(--royal); border-radius: 3px; }

/* Round label row */
.round-labels {
  display: flex;
  align-items: center;
  min-width: 1300px;
  margin-bottom: 6px;
}

.rl {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  text-align: center;
  color: var(--muted);
  flex-shrink: 0;
}
.rl.r32 { width: var(--mw); }
.rl.gap { width: 38px; }
.rl.r16 { width: var(--mw); }
.rl.qf  { width: var(--mw); }
.rl.ctr { flex: 1; color: var(--gold); font-size: 10px; min-width: 200px; }

/* Bracket canvas */
#bc {
  display: flex;
  align-items: stretch;
  min-width: 1300px;
  min-height: 900px;
  position: relative;
}

/* Overlay SVG for all connectors */
#bc-svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  overflow: visible;
}

/* Side panels */
#lp, #rp {
  display: flex;
  align-items: stretch;
  flex-shrink: 0;
  z-index: 1;
}

/* Center panel */
#cp {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 0 12px;
  min-width: 200px;
  z-index: 1;
  position: relative;
}

/* Round columns */
.rc {
  width: var(--mw);
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  align-items: stretch;
  position: relative;
  z-index: 1;
}

/* Gap strips between rounds */
.rg {
  width: 38px;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

/* ═══════════════════════════════════════════
   MATCH BOX
═══════════════════════════════════════════ */
.mb {
  background: linear-gradient(160deg, var(--box), var(--box2));
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: visible;
  position: relative;
  transition: border-color .18s, box-shadow .18s, transform .12s;
  cursor: default;
  backdrop-filter: blur(6px);
  flex-shrink: 0;
}

.mb:hover {
  border-color: rgba(74,140,255,0.7);
  box-shadow: 0 0 18px rgba(74,140,255,0.2), 0 4px 14px rgba(0,0,0,0.4);
  transform: translateY(-1px);
  z-index: 10;
}

.mb.final {
  border-color: var(--border-gld);
  box-shadow: 0 0 28px rgba(255,215,0,0.18), 0 6px 24px rgba(0,0,0,0.5);
  background: linear-gradient(160deg, #12266E, #0A185A);
}

.mb.final:hover {
  box-shadow: 0 0 40px rgba(255,215,0,0.3), 0 8px 32px rgba(0,0,0,0.5);
  border-color: rgba(255,215,0,0.8);
}

/* Team rows */
.mt {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 7px 9px;
  min-height: 28px;
  transition: background .12s;
}

.mt:first-child { border-bottom: 1px solid rgba(74,140,255,0.12); }
.mt:hover { background: rgba(74,140,255,0.07); }

.tf {
  font-size: 18px;
  flex-shrink: 0;
  width: 28px;
  min-width: 28px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.tf img {
  display: block;
  width: 24px;
  height: 16px;
  object-fit: cover;
  border-radius: 2px;
}
.tn { font-size: 11px; font-weight: 700; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ts { font-size: 8px; font-weight: 600; color: var(--muted); flex-shrink: 0; white-space: nowrap; }
.mt:not(.tbd) .ts,
.mt.scored .ts {
  font-size: 11px;
  font-weight: 800;
  color: #fff;
}

.mt.tbd .tn { color: var(--muted); font-style: italic; font-weight: 400; }
.mt.tbd .tf { opacity: 0.35; }

/* Date stripe */
.md {
  font-size: 9px;
  font-weight: 800;
  color: rgba(220,232,255,0.78);
  text-align: right;
  padding: 2px 8px 3px;
  letter-spacing: .5px;
}

/* ═══════════════════════════════════════════
   CENTER COLUMN COMPONENTS
═══════════════════════════════════════════ */
.trophy-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  position: relative;
  margin-bottom: 14px;
}

.trophy-glow {
  position: absolute;
  width: 170px; height: 170px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,215,0,0.22) 0%, transparent 68%);
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  pointer-events: none;
  animation: tpulse 3.2s ease-in-out infinite;
}

@keyframes tpulse {
  0%,100% { opacity:.65; transform: translate(-50%,-50%) scale(1);   }
  50%      { opacity:1;   transform: translate(-50%,-50%) scale(1.18); }
}

.trophy-icon {
  font-size: 76px;
  line-height: 1;
  filter: drop-shadow(0 0 18px rgba(255,215,0,.8)) drop-shadow(0 4px 8px rgba(0,0,0,.6));
  animation: tfloat 4s ease-in-out infinite;
  position: relative;
  z-index: 1;
}

@keyframes tfloat {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-7px); }
}

.trophy-lbl {
  font-size: 8.5px;
  font-weight: 800;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--gold);
  text-shadow: 0 0 10px rgba(255,215,0,.5);
}

/* Semi wrappers */
.sf-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.sf-lbl {
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--muted);
  text-transform: uppercase;
}

.final-wrap .sf-lbl {
  font-size: 9px;
  font-weight: 800;
  color: #ffffff;
}

/* Final wrapper */
.final-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  margin: 14px 0;
}

.final-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(135deg, rgba(255,215,0,0.13), rgba(255,215,0,0.04));
  border: 1px solid rgba(255,215,0,0.42);
  border-radius: 100px;
  padding: 4px 15px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1px;
  color: var(--gold);
}

/* Champion */
.champ-wrap {
  width: 100%;
  margin-top: 12px;
  text-align: center;
  min-height: 38px;
}

.champ-name {
  font-size: 16px;
  font-weight: 900;
  letter-spacing: 2px;
  text-transform: uppercase;
  background: linear-gradient(90deg, var(--gold) 0%, #fff5a0 50%, var(--gold) 100%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 2s linear infinite;
}

@keyframes shimmer {
  0%   { background-position: 0%   center; }
  100% { background-position: 200% center; }
}

.champ-sub {
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 3px;
  color: var(--gold);
  text-transform: uppercase;
  opacity: .6;
}

/* ═══════════════════════════════════════════
   GROUPS
═══════════════════════════════════════════ */
.groups-section {
  padding: 40px 20px 60px;
  border-top: 1px solid rgba(74,140,255,0.13);
}

.groups-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 9px;
  max-width: 1700px;
  margin: 0 auto;
}

@media (max-width:1400px) { .groups-grid { grid-template-columns: repeat(6,1fr); } }
@media (max-width:900px)  { .groups-grid { grid-template-columns: repeat(4,1fr); } }
@media (max-width:600px)  { .groups-grid { grid-template-columns: repeat(3,1fr); } }

.gc {
  background: linear-gradient(160deg, rgba(12,30,107,0.85), rgba(9,24,88,0.85));
  border: 1px solid rgba(74,140,255,0.2);
  border-radius: 12px;
  overflow: hidden;
  transition: border-color .2s, box-shadow .2s;
  backdrop-filter: blur(6px);
}

.gc:hover {
  border-color: rgba(74,140,255,0.5);
  box-shadow: 0 4px 18px rgba(74,140,255,0.14);
}

.gh {
  background: linear-gradient(135deg, #091C60, #050E38);
  padding: 8px 10px;
  text-align: center;
  border-bottom: 1px solid rgba(74,140,255,0.22);
}

.gl {
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 1px;
  color: var(--acc);
}

.gt { display: flex; flex-direction: column; }

.gtr {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 7px 9px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  transition: background .13s;
}
.gtr:last-child { border-bottom: none; }
.gtr:hover { background: rgba(74,140,255,0.07); }

.gf {
  font-size: 15px;
  flex-shrink: 0;
  width: 28px;
  min-width: 28px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.gf img {
  display: block;
  width: 24px;
  height: 16px;
  object-fit: cover;
  border-radius: 2px;
}
.gn { font-size: 9.5px; font-weight: 700; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* ═══════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════ */
.site-footer {
  text-align: center;
  padding: 18px;
  font-size: 10px;
  letter-spacing: 1.5px;
  color: var(--muted);
  border-top: 1px solid rgba(74,140,255,0.1);
}

/* ═══════════════════════════════════════════
   SCROLLBAR
═══════════════════════════════════════════ */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--royal); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--acc); }
</style>
</head>
<body>

<!-- HEADER -->
<header class="site-header" role="banner">
  <nav class="bracket-nav" aria-label="Menu principal">
    <div class="bracket-nav-inner">
      <a class="bracket-nav-link active" href="/">Inicio</a>
      <div class="bracket-nav-dropdown">
        <button class="bracket-nav-dropbtn" type="button">Mundial_2026</button>
        <div class="bracket-nav-menu">
                  <li><a class="bracket-nav-item" href="/ranking">Ranking</a></li>                                    
                  <li><a class="bracket-nav-item" href="/resultados">Resultados</a></li>
                  <li><a class="bracket-nav-item" href="/quinielas">Quinielas</a></li>
                  <li><a class="bracket-nav-item" href="/calendario">Calendario</a></li>
                  <li><a class="bracket-nav-item" href="/grupos">Grupos</a></li>
                  <li><a class="bracket-nav-item" href="/bracket">Bracket</a></li>                  
                  <li><hr class="dropdown-divider"></li>
                  <li><a class="bracket-nav-item" href="/paises">Paises</a></li>
                  <li><a class="bracket-nav-item" href="/estadios">Estadios</a></li>
                  <li><a class="bracket-nav-item" href="/mundiales">Mundiales</a></li>
                  <li><a class="bracket-nav-item" href="/musica">Musica</a></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><a class="bracket-nav-item" href="/guia">Guia</a></li>
        </div>
      </div>
      <div class="bracket-nav-spacer"></div>
      <a class="bracket-nav-link" href="/salir">Salir</a>
    </div>
  </nav>
</header>

<!-- BRACKET -->
<section class="bracket-section" aria-label="Bracket de eliminación directa">
  <div class="scroll-wrap">
    <!-- Round Labels -->
    <div class="round-labels">
      <div class="rl r32">DIECISEISAVOS</div>
      <div class="rl gap"></div>
      <div class="rl r16">OCTAVOS</div>
      <div class="rl gap"></div>
      <div class="rl qf">CUARTOS</div>
      <div class="rl ctr">SEMIFINALES &amp; FINAL</div>
      <div class="rl qf">CUARTOS</div>
      <div class="rl gap"></div>
      <div class="rl r16">OCTAVOS</div>
      <div class="rl gap"></div>
      <div class="rl r32">DIECISEISAVOS</div>
    </div>

    <!-- Bracket Canvas -->
    <div id="bc">
      <!-- SVG overlay for connectors -->
      <svg id="bc-svg" xmlns="http://www.w3.org/2000/svg"></svg>

      <!-- LEFT panel -->
      <div id="lp">
        <div class="rc" id="L-R32"></div>
        <div class="rg" id="g-L-R32-R16"></div>
        <div class="rc" id="L-R16"></div>
        <div class="rg" id="g-L-R16-QF"></div>
        <div class="rc" id="L-QF"></div>
        <div class="rg" id="g-L-QF-SF"></div>
      </div>

      <!-- CENTER panel -->
      <div id="cp">
        <button id="bracket-toggle-btn" class="bracket-toggle-btn" type="button">Calcular bracket</button>

        <div class="trophy-wrap">
          <div class="trophy-glow"></div>
          <div class="trophy-icon" role="img" aria-label="Trofeo FIFA World Cup">🏆</div>
          <div class="trophy-lbl">MUNDIAL MEX CAN USA 2026</div>
        </div>

        <div class="sf-wrap">
          <div class="sf-lbl">Semifinal</div>
          <div id="SF-L" style="width:100%"></div>
        </div>

        <div class="final-wrap">
          <div class="final-badge">🏟️ &nbsp;104 · NYNJ · 19-jul</div>
          <div class="sf-lbl">GRAN FINAL</div>
          <div id="FINAL-BOX" style="width:100%"></div>
        </div>

        <div class="sf-wrap">
          <div class="sf-lbl">Semifinal</div>
          <div id="SF-R" style="width:100%"></div>
        </div>

        <div class="champ-wrap" id="champ-wrap"></div>
      </div>

      <!-- RIGHT panel -->
      <div id="rp">
        <div class="rg" id="g-R-QF-SF"></div>
        <div class="rc" id="R-QF"></div>
        <div class="rg" id="g-R-QF-R16"></div>
        <div class="rc" id="R-R16"></div>
        <div class="rg" id="g-R-R16-R32"></div>
        <div class="rc" id="R-R32"></div>
      </div>
    </div>
  </div>
</section>

<!-- GROUPS -->
<section class="groups-section" aria-label="Fase de grupos FIFA World Cup 2026">
  <p class="sec-title">GROUPS</p>
  <div class="groups-grid" id="groups-grid"></div>
</section>

