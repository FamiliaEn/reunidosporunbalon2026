/** Build a .mb match-box element */
function mkBox(match, opts = {}) {
  const { isFinal = false } = opts;
  const box = document.createElement('div');
  box.className = 'mb' + (isFinal ? ' final' : '');
  box.id = 'box-' + match.id;

  const hasA = match.teamA;
  const hasB = match.teamB;

  const flagA = hasA ? match.teamA.flag : '🏳';
  const nameA = hasA ? match.teamA.name : (match.seedA || 'TBD');
  const seedA = match.scoreA ?? match.seedA ?? '';
  const hasScoreA = match.scoreA !== undefined && match.scoreA !== null;

  const flagB = hasB ? match.teamB.flag : '🏳';
  const nameB = hasB ? match.teamB.name : (match.seedB || 'TBD');
  const seedB = match.scoreB ?? match.seedB ?? '';
  const hasScoreB = match.scoreB !== undefined && match.scoreB !== null;

  box.innerHTML =
    `<div class="mt${hasA ? '' : ' tbd'}${hasScoreA ? ' scored' : ''}">` +
      `<span class="tf">${hasA ? flagA : '🏳'}</span>` +
      `<span class="tn">${nameA}</span>` +
      `<span class="ts">${seedA}</span>` +
    `</div>` +
    `<div class="mt${hasB ? '' : ' tbd'}${hasScoreB ? ' scored' : ''}">` +
      `<span class="tf">${hasB ? flagB : '🏳'}</span>` +
      `<span class="tn">${nameB}</span>` +
      `<span class="ts">${seedB}</span>` +
    `</div>` +
    (match.date ? `<div class="md">${match.date}</div>` : '');

  return box;
}

/** Fill a round column (.rc) with match boxes */
function fillCol(colId, matches, opts = {}) {
  const col = document.getElementById(colId);
  if (!col) return;
  matches.forEach(m => col.appendChild(mkBox(m, opts)));
}

/** Get the center Y of an element relative to the bracket canvas */
function midY(el) {
  const canv = document.getElementById('bc');
  const cr = canv.getBoundingClientRect();
  const er = el.getBoundingClientRect();
  return er.top + er.height / 2 - cr.top;
}

/** Get the center X of an element relative to the bracket canvas */
function midX(el) {
  const canv = document.getElementById('bc');
  const cr = canv.getBoundingClientRect();
  const er = el.getBoundingClientRect();
  return er.left + er.width / 2 - cr.left;
}

/** Right edge X of an element relative to canvas */
function rightX(el) {
  const canv = document.getElementById('bc');
  const cr = canv.getBoundingClientRect();
  const er = el.getBoundingClientRect();
  return er.right - cr.left;
}

/** Left edge X of an element relative to canvas */
function leftX(el) {
  const canv = document.getElementById('bc');
  const cr = canv.getBoundingClientRect();
  const er = el.getBoundingClientRect();
  return er.left - cr.left;
}

/** Draw SVG connector lines
 *  @param {SVGElement} svg
 *  @param {number[]} pts flat array [x0,y0, x1,y1, ...]
 */
function line(svg, ...pts) {
  const ns = 'http://www.w3.org/2000/svg';
  const pl = document.createElementNS(ns, 'polyline');
  const pStr = [];
  for (let i = 0; i < pts.length; i += 2) pStr.push(`${pts[i]},${pts[i+1]}`);
  pl.setAttribute('points', pStr.join(' '));
  pl.setAttribute('fill', 'none');
  pl.setAttribute('stroke', 'rgba(74,140,255,0.38)');
  pl.setAttribute('stroke-width', '1.6');
  pl.setAttribute('stroke-linecap', 'round');
  pl.setAttribute('stroke-linejoin', 'round');
  svg.appendChild(pl);
}

/**
 * Connect pairs of boxes from "from" column to single boxes in "to" column.
 * Side: 'L' = from-col is to the LEFT of to-col
 *        'R' = from-col is to the RIGHT of to-col
 */
function connectRounds(svg, fromColId, toColId, side) {
  const fromBoxes = [...document.getElementById(fromColId).querySelectorAll('.mb')];
  const toBoxes   = [...document.getElementById(toColId).querySelectorAll('.mb')];

  toBoxes.forEach((toBox, i) => {
    const fA = fromBoxes[i * 2];
    const fB = fromBoxes[i * 2 + 1];
    if (!fA || !fB) return;

    const yA   = midY(fA);
    const yB   = midY(fB);
    const yTo  = midY(toBox);
    const yMid = (yA + yB) / 2;

    if (side === 'L') {
      // from-col left → to-col right: exit right, go to mid, enter left
      const xFrom = rightX(fA);   // both fA/fB share same right X
      const xTo   = leftX(toBox);
      const xMid  = (xFrom + xTo) / 2;

      line(svg, xFrom, yA,   xMid, yA,   xMid, yMid);
      line(svg, xFrom, yB,   xMid, yB,   xMid, yMid);
      line(svg, xMid, yMid,  xTo,  yMid, xTo,  yTo);
    } else {
      // from-col right → to-col left: exit left, go to mid, enter right
      const xFrom = leftX(fA);
      const xTo   = rightX(toBox);
      const xMid  = (xFrom + xTo) / 2;

      line(svg, xFrom, yA,   xMid, yA,   xMid, yMid);
      line(svg, xFrom, yB,   xMid, yB,   xMid, yMid);
      line(svg, xMid, yMid,  xTo,  yMid, xTo,  yTo);
    }
  });
}

/**
 * Connect QF column (2 boxes) to a single SF box in center panel.
 * For left side: QF right edge → SF left edge.
 * For right side: QF left edge → SF right edge.
 */
function connectQFtoSF(svg, qfColId, sfBoxId, side) {
  const qfBoxes = [...document.getElementById(qfColId).querySelectorAll('.mb')];
  const sfBox   = document.getElementById(sfBoxId).querySelector('.mb');
  if (!sfBox) return;

  const yTo = midY(sfBox);

  qfBoxes.forEach(qb => {
    const yFrom = midY(qb);
    if (side === 'L') {
      const xFrom = rightX(qb);
      const xTo   = leftX(sfBox);
      const xMid  = (xFrom + xTo) / 2;
      line(svg, xFrom, yFrom, xMid, yFrom, xMid, yTo, xTo, yTo);
    } else {
      const xFrom = leftX(qb);
      const xTo   = rightX(sfBox);
      const xMid  = (xFrom + xTo) / 2;
      line(svg, xFrom, yFrom, xMid, yFrom, xMid, yTo, xTo, yTo);
    }
  });
}

/**
 * Connect SF boxes to the FINAL box.
 */
function connectSFtoFinal(svg) {
  const sfL   = document.getElementById('SF-L').querySelector('.mb');
  const sfR   = document.getElementById('SF-R').querySelector('.mb');
  const final = document.getElementById('FINAL-BOX').querySelector('.mb');
  if (!sfL || !sfR || !final) return;

  // SF-L → Final (left side, SF is above+left of final)
  [{ sf: sfL, side: 'L' }, { sf: sfR, side: 'R' }].forEach(({ sf, side }) => {
    const yFrom = midY(sf);
    const yTo   = midY(final);
    if (side === 'L') {
      const xFrom = rightX(sf);
      const xTo   = leftX(final);
      const xMid  = (xFrom + xTo) / 2;
      line(svg, xFrom, yFrom, xMid, yFrom, xMid, yTo, xTo, yTo);
    } else {
      const xFrom = leftX(sf);
      const xTo   = rightX(final);
      const xMid  = (xFrom + xTo) / 2;
      line(svg, xFrom, yFrom, xMid, yFrom, xMid, yTo, xTo, yTo);
    }
  });
}

/** Draw all connectors */
function drawAll() {
  const svg = document.getElementById('bc-svg');
  svg.innerHTML = '';

  // Resize svg viewBox to canvas
  const canv = document.getElementById('bc');
  const w = canv.offsetWidth, h = canv.offsetHeight;
  svg.setAttribute('viewBox', `0 0 ${w} ${h}`);

  // Left: R32 → R16 → QF
  connectRounds(svg, 'L-R32', 'L-R16', 'L');
  connectRounds(svg, 'L-R16', 'L-QF',  'L');

  // Right: R32 → R16 → QF  (mirrored)
  connectRounds(svg, 'R-R32', 'R-R16', 'R');
  connectRounds(svg, 'R-R16', 'R-QF',  'R');

  // QF → SF (center)
  connectQFtoSF(svg, 'L-QF', 'SF-L', 'L');
  connectQFtoSF(svg, 'R-QF', 'SF-R', 'R');

  // SF → Final
  connectSFtoFinal(svg);
}

/* ── GROUPS ── */
async function fetchBracketGroups() {
  const response = await fetch('/bracket_data');
  if (!response.ok) {
    throw new Error(`Error cargando grupos: ${response.status}`);
  }
  return response.json();
}

async function fetchBracketScores(ids) {
  if (!ids.length) return [];

  const response = await fetch(`/bracket_scores?ids=${ids.join(',')}`);
  if (!response.ok) {
    throw new Error(`Error cargando marcadores: ${response.status}`);
  }
  return response.json();
}

function normalizeBracketGroups(rows) {
  return rows.reduce((groups, row) => {
    const groupId = row.Grupo || row.grupo || 'Sin grupo';
    if (!groups[groupId]) {
      groups[groupId] = [];
    }
    groups[groupId].push({
      code: row.Clave || row.clave || '',
      name: row.Nombre || row.nombre || ''
    });
    return groups;
  }, {});
}

function renderGroups(groupsData) {
  const grid = document.getElementById('groups-grid');
  grid.innerHTML = '';
  Object.entries(groupsData).forEach(([letter, teams]) => {
    const card = document.createElement('div');
    card.className = 'gc';
    card.setAttribute('aria-label', `Grupo ${letter}`);
    card.innerHTML =
      `<div class="gh"><div class="gl">GRUPO ${letter}</div></div>` +
      `<div class="gt">${teams.map(t =>
        `<div class="gtr">` +
          `<img class="gf" src="/resources/Ipais/${t.code}.png" alt="${t.name}" width="24" height="16" ` +
            `onerror="this.onerror=null;this.src='https://placehold.co/24x16?text=${t.code}'"/>` +
          `<span class="gn">${t.name}</span>` +
        `</div>`
      ).join('')}</div>`;
    grid.appendChild(card);
  });
}

async function loadBracketGroups() {
  try {
    const rows = await fetchBracketGroups();
    const groupsData = normalizeBracketGroups(rows);
    renderGroups(groupsData);
  } catch (error) {
    console.error(error);
  }
}

function resetBracketData() {
  getBracketMatches().forEach(match => {
    delete match.scoreA;
    delete match.scoreB;
  });

  getR32Matches().forEach(match => {
    delete match.teamA;
    delete match.teamB;
  });
}

function clearBracketContainers() {
  ['L-R32','L-R16','L-QF','R-R32','R-R16','R-QF','SF-L','SF-R','FINAL-BOX','champ-wrap'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = '';
  });
}

function renderBracketMatches() {
  clearBracketContainers();

  fillCol('L-R32', DATA.R32_L);
  fillCol('L-R16', DATA.R16_L);
  fillCol('L-QF',  DATA.QF_L);
  fillCol('R-R32', DATA.R32_R);
  fillCol('R-R16', DATA.R16_R);
  fillCol('R-QF',  DATA.QF_R);

  document.getElementById('SF-L').appendChild(mkBox(DATA.SF_L));
  document.getElementById('SF-R').appendChild(mkBox(DATA.SF_R));
  document.getElementById('FINAL-BOX').appendChild(mkBox(DATA.FINAL, { isFinal: true }));

  const thirdPlaceWrap = document.getElementById('champ-wrap');
  thirdPlaceWrap.innerHTML = '<div class="sf-lbl">TERCER LUGAR</div>';
  thirdPlaceWrap.appendChild(mkBox(DATA.THIRD_PLACE));
}

async function calculateBracket() {
  const button = document.getElementById('bracket-toggle-btn');
  if (button) button.disabled = true;

  try {
    const scoreIds = getBracketMatches().map(getMatchDbId).filter(id => id !== null);
    const [rows, scoreRows] = await Promise.all([
      fetchBracketGroups(),
      fetchBracketScores(scoreIds)
    ]);
    const groupsData = normalizeBracketGroups(rows);
    attachR32Teams(groupsData);
    attachBracketScores(scoreRows);
    renderBracketMatches();
    requestAnimationFrame(drawAll);
  } catch (error) {
    console.error(error);
  } finally {
    if (button) button.disabled = false;
  }
}

function getR32Matches() {
  return [...DATA.R32_L, ...DATA.R32_R];
}

function getBracketMatches() {
  return [
    ...DATA.R32_L,
    ...DATA.R32_R,
    ...DATA.R16_L,
    ...DATA.R16_R,
    ...DATA.QF_L,
    ...DATA.QF_R,
    DATA.SF_L,
    DATA.SF_R,
    DATA.FINAL,
    DATA.THIRD_PLACE
  ];
}

function getMatchDbId(match) {
  const matchId = String(match.id || '').match(/-(\d+)$/);
  return matchId ? Number(matchId[1]) : null;
}

function attachBracketScores(scoreRows) {
  const scoresById = new Map(
    scoreRows.map(row => [Number(row.Id), row])
  );

  getBracketMatches().forEach(match => {
    const dbId = getMatchDbId(match);
    const score = scoresById.get(dbId);
    if (!score) return;

    match.scoreA = score.ML;
    match.scoreB = score.MV;
  });
}

function attachR32Teams(groupsData) {
  const seedMatch = /^([1-3])([A-L])$/i;
  const thirdMatch = /^3([A-L]{3,})$/i;

  Object.values(groupsData).forEach(teams => {
    teams.forEach(team => {
      const code = String(team.code || '').trim().toUpperCase();
      const originalName = team.name || code;
      team.code = code;
      team.flag = code
        ? `<img src="/resources/Ipais/${code}.png" alt="${originalName}" width="24" height="16" onerror="this.onerror=null;this.src='https://placehold.co/24x16?text=${code}'"/>`
        : team.flag;
      team.name = code || originalName;
    });
  });

  const placeholder = seed => ({ code: seed, name: seed, flag: '🏳' });

  const getTeam = seed => {
    const directMatch = seedMatch.exec(seed);
    if (directMatch) {
      const position = Number(directMatch[1]) - 1;
      const groupId = directMatch[2].toUpperCase();
      const team = groupsData[groupId]?.[position];
      return team ? { ...team, flag: team.flag || team.code || '🏳' } : placeholder(seed);
    }

    const thirdMatchResult = thirdMatch.exec(seed);
    if (thirdMatchResult) {
      const groups = thirdMatchResult[1].split('').join('/');
      return { code: seed, name: `3° ${groups}`, flag: '🏳' };
    }

    if (seed.startsWith('W ') || seed.startsWith('w ')) {
      return { code: seed, name: seed, flag: '🏳' };
    }

    return placeholder(seed);
  };

  [DATA.R32_L, DATA.R32_R].forEach(round => {
    round.forEach(match => {
      match.teamA = getTeam(match.seedA);
      match.teamB = getTeam(match.seedB);
    });
  });
}

async function loadBracketTeams() {
  try {
    const rows = await fetchBracketGroups();
    const groupsData = normalizeBracketGroups(rows);
    attachR32Teams(groupsData);
  } catch (error) {
    console.error(error);
  }
}

function setupBracketToggle() {
  const button = document.getElementById('bracket-toggle-btn');
  if (!button) return;

  let bracketCalculated = false;

  button.addEventListener('click', async () => {
    if (bracketCalculated) {
      resetBracketData();
      renderBracketMatches();
      requestAnimationFrame(drawAll);
      button.textContent = 'Calcular bracket';
      bracketCalculated = false;
    } else {
      await calculateBracket();
      button.textContent = 'Regresar al origen';
      bracketCalculated = true;
    }
  });
}

/* ── INIT ── */
async function init() {
  loadBracketGroups();
  setupBracketToggle();

  renderBracketMatches();

  // Equalize round column heights to canvas height for space-around to work
  requestAnimationFrame(() => {
    const canv = document.getElementById('bc');
    const h = canv.offsetHeight;
    ['L-R32','L-R16','L-QF','R-R32','R-R16','R-QF'].forEach(id => {
      const c = document.getElementById(id);
      if (c) c.style.height = h + 'px';
    });

    // Draw connectors after second rAF (ensure layout complete)
    requestAnimationFrame(() => {
      setTimeout(drawAll, 50);
    });
  });
}

// Re-draw on resize
let rt;
window.addEventListener('resize', () => {
  clearTimeout(rt);
  rt = setTimeout(() => {
    const canv = document.getElementById('bc');
    const h = canv.offsetHeight;
    ['L-R32','L-R16','L-QF','R-R32','R-R16','R-QF'].forEach(id => {
      const c = document.getElementById(id);
      if (c) c.style.height = h + 'px';
    });
    drawAll();
  }, 160);
});

document.addEventListener('DOMContentLoaded', init);
</script>
</body>
</html>
