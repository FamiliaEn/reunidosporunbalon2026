<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta1/dist/js/bootstrap.bundle.min.js" integrity="sha384-ygbV9kiqUc6oa4msXn9868pTtWMgiQaeYH7/t7LECLbyPA2x65Kgf80OJFdroafW" crossorigin="anonymous"></script>
<script>
        async function fetchGroupsData() {
            const response = await fetch('/grupos_data');
            if (!response.ok) {
                throw new Error(`Error al cargar grupos: ${response.status}`);
            }
            return response.json();
        }

        function normalizeGroupRows(rows) {
            return rows.reduce((groups, row) => {
                const groupId = row.Grupo || row.grupo || 'Sin grupo';
                if (!groups[groupId]) {
                    groups[groupId] = [];
                }
                groups[groupId].push({
                    cod: row.Clave || row.cod || '',
                    pais: row.Nombre || row.pais || '',
                    jj: row.JJ ?? row.jj ?? 0,
                    jg: row.JG ?? row.jg ?? 0,
                    je: row.JE ?? row.je ?? 0,
                    jp: row.JP ?? row.jp ?? 0,
                    gf: row.GF ?? row.gf ?? 0,
                    gc: row.GC ?? row.gc ?? 0,
                    dg: row.DG ?? row.dg ?? 0,
                    pts: row.PTS ?? row.pts ?? 0
                });
                return groups;
            }, {});
        }

        function renderGroups(groupsData) {
            const container = document.getElementById('groups-container');
            container.innerHTML = '';

            Object.entries(groupsData).forEach(([groupId, teams]) => {
                const groupCard = document.createElement('div');
                groupCard.className = 'bg-athletic-white rounded-xl shadow-sm border border-stats-border overflow-hidden surface-level-1';

                const header = `
                    <div class="bg-points-accent text-athletic-white font-headline-group text-headline-group py-3 px-card-padding text-center uppercase tracking-wide">
                        Grupo ${groupId}
                    </div>
                `;

                let tableRows = '';
                teams.forEach((team, index) => {
                    const dgDisplay = team.dg > 0 ? `+${team.dg}` : team.dg;
                    const flagCode = String(team.cod || '').trim().toUpperCase();
                    tableRows += `
                        <tr class="${index < teams.length - 1 ? 'border-b border-stats-border' : ''} hover:bg-surface-container transition-colors bg-surface-container-lowest">
                            <td class="text-left py-2 px-card-padding flex items-center gap-3 min-w-[280px]">
                                <span class="font-bold text-outline text-xs w-4">${index + 1}</span>
                                <img alt="${team.pais}" class="flag-icon h-[25px] w-[35px] object-cover border border-stats-border rounded-[2px] shrink-0" src="/resources/Ipais/${flagCode}.png" width="35" height="25" onerror="this.onerror=null;this.src='https://placehold.co/35x25?text=${flagCode}'"/>
                                <span class="font-body-team-name text-body-team-name font-bold uppercase text-left whitespace-nowrap leading-none">${team.pais}</span>
                            </td>
                            <td class="py-2 px-2 w-10">${team.jj}</td>
                            <td class="py-2 px-2 w-10">${team.jg}</td>
                            <td class="py-2 px-2 w-10">${team.je}</td>
                            <td class="py-2 px-2 w-10">${team.jp}</td>
                            <td class="py-2 px-2 w-10">${team.gf}</td>
                            <td class="py-2 px-2 w-10">${team.gc}</td>
                            <td class="py-2 px-2 w-10">${dgDisplay}</td>
                            <td class="py-2 px-card-padding w-14 font-data-pts text-data-pts text-primary bg-surface/30 font-bold">${team.pts}</td>
                        </tr>
                    `;
                });

                groupCard.innerHTML = `
                    ${header}
                    <div class="overflow-x-auto">
                        <table class="w-full text-center border-collapse">
                            <thead class="bg-surface border-b border-stats-border text-on-surface-variant font-table-header text-table-header uppercase">
                                <tr>
                                    <th class="text-left py-3 px-card-padding font-bold min-w-[280px]">Equipo</th>
                                    <th class="py-3 px-2 w-10">JJ</th>
                                    <th class="py-3 px-2 w-10">JG</th>
                                    <th class="py-3 px-2 w-10">JE</th>
                                    <th class="py-3 px-2 w-10">JP</th>
                                    <th class="py-3 px-2 w-10">GF</th>
                                    <th class="py-3 px-2 w-10">GC</th>
                                    <th class="py-3 px-2 w-10">DG</th>
                                    <th class="py-3 px-card-padding w-14 text-primary font-bold">PTS</th>
                                </tr>
                            </thead>
                            <tbody class="font-data-number text-data-number text-on-surface">
                                ${tableRows}
                            </tbody>
                        </table>
                    </div>
                `;
                container.appendChild(groupCard);
            });
        }

        async function loadGroupStandings() {
            const container = document.getElementById('groups-container');
            container.innerHTML = '<div class="col-span-full text-center text-on-surface-variant">Cargando clasificación...</div>';

            try {
                const rows = await fetchGroupsData();
                const groupsData = normalizeGroupRows(rows);
                renderGroups(groupsData);
            } catch (error) {
                console.error(error);
                container.innerHTML = '<div class="col-span-full text-center text-error">No se pudo cargar la clasificación. Intenta de nuevo más tarde.</div>';
            }
        }

        document.addEventListener('DOMContentLoaded', loadGroupStandings);
    </script>
