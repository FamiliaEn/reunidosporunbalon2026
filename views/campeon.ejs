<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-giJF6kkoqNQ00vy+HMDP7azOuL0xtbfIcaT9wjKHr8RbDVddVHyTfAAsrekwKmP1" crossorigin="anonymous">

 
    <link  rel="stylesheet" href="../resources/css/estilo.css" >

    <title>EDITA</title>
    <style>
      .campeon-grid {
        max-width: 760px;
        margin: 0 auto 24px;
        row-gap: 18px;
      }

      .campeon-card {
        height: 100%;
        padding: 18px 16px;
        border: 1px solid rgba(13, 110, 253, 0.22);
        border-radius: 10px;
        background: linear-gradient(180deg, rgba(13, 110, 253, 0.08), rgba(255, 255, 255, 0.92));
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.08);
      }

      .campeon-label {
        margin-bottom: 8px;
        color: #0d6efd;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .campeon-current {
        min-height: 34px;
        margin-bottom: 14px;
        color: #172033;
        font-size: 1.15rem;
        font-weight: 800;
      }

      .campeon-select-label {
        display: block;
        margin-bottom: 6px;
        color: #5b6472;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
      }

      .campeon-select {
        width: 100%;
        min-height: 42px;
        padding: 8px 36px 8px 12px;
        border: 1px solid rgba(13, 110, 253, 0.35);
        border-radius: 8px;
        color: #172033;
        font-weight: 700;
        background-color: #fff;
      }

      .campeon-display {
        min-width: 190px;
        padding: 12px 14px;
        border: 1px solid rgba(13, 110, 253, 0.24);
        border-radius: 10px;
        background: #fff;
        color: #172033;
        font-size: 1.05rem;
        font-weight: 800;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
      }

      select[name="campeon"],
      select[name="SubCampeon"] {
        width: 100%;
        min-width: 190px;
        min-height: 42px;
        padding: 8px 12px;
        border: 1px solid rgba(13, 110, 253, 0.38);
        border-radius: 8px;
        background-color: #fff;
        color: #172033;
        font-size: 0.96rem;
        font-weight: 700;
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.12);
      }

      select[name="campeon"]:focus,
      select[name="SubCampeon"]:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.18);
        outline: none;
      }
    </style>
</head>
<body>

