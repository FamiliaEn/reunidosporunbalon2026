                    <label class="campeon-select-label" for="campeon">Elegir campeón</label>
                    <select id="campeon" name="campeon" class="campeon-select">
                      <% equiposCuartos.forEach((equipo) => { %>
                        <option value="<%= equipo.Equipo %>" <%= campeonInfo && campeonInfo.Equipo === equipo.Equipo ? 'selected' : '' %>><%= equipo.Equipo %></option>
